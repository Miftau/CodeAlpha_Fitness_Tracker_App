{
  "expo": {
    "name": "FitnessTracker",
    "slug": "FitnessTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/image.png",
    "scheme": "fitnesstracker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devprogress.fitnesstracker",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.devprogress.fitnesstracker",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/image.png",
          "color": "#ffffff",
          "sounds": [
            "./src/assets/sounds/workout.mp3"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "57cbc782-c93b-41ba-9912-d672b05ac6d7"
      }
    }
  }
}